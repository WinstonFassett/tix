cmd_show() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: tix show <id>" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    local target_id
    target_id=$(basename "$file" .md)
    
    # Build file list properly handling spaces
    local -a ticket_files
    while IFS= read -r -d '' file_item; do
        ticket_files+=("$file_item")
    done < <(find "$TICKETS_DIR" -type f -name "*.md" -print0 2>/dev/null)

    awk -v target="$target_id" -v target_file="$file" '
    BEGIN { FS=": "; in_front=0 }

    # First pass: collect all ticket metadata
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; fm_title=""; deps=""; links=""; parent=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^title:/ { fm_title = substr($0, 8); gsub(/^["'\'']+|["'\'']+$/, "", fm_title) }
    in_front && /^status:/ { status = $2 }
    in_front && /^deps:/ { deps = $2; gsub(/[\[\] ]/, "", deps) }
    in_front && /^links:/ { links = $2; gsub(/[\[\] ]/, "", links) }
    in_front && /^parent:/ { parent = $2 }
    !in_front && /^# / && title == "" { title = substr($0, 3) }

    function is_terminal(s) {
        return (s == "done" || s == "closed" || s == "completed" || s == "finished" || s == "resolved" || s == "cancelled" || s == "canceled" || s == "wontfix")
    }
    function store() {
        if (title == "" && fm_title != "") title = fm_title
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            all_deps[id] = deps
            all_links[id] = links
            parents[id] = parent
        }
    }

    END {
        if (prev_file) store()

        # Build inverse relationships
        for (id in statuses) {
            # Children: tickets where parent == target
            if (parents[id] == target) {
                children_count++
                children[children_count] = id
            }
            # Blocking: tickets where target is in their deps
            deps = all_deps[id]
            if (deps != "") {
                n = split(deps, arr, ",")
                for (i = 1; i <= n; i++) {
                    if (arr[i] == target && !is_terminal(statuses[id])) {
                        blocking_count++
                        blocking[blocking_count] = id
                    }
                }
            }
        }

        # Now output the target file with enhancements
        in_front = 0
        while ((getline line < target_file) > 0) {
            if (line == "---") {
                in_front = !in_front
                print line
            } else if (in_front && line ~ /^parent:/) {
                # Add parent title as comment
                p = line
                sub(/^parent: */, "", p)
                if (p in titles) {
                    print line "  # " titles[p]
                } else {
                    print line
                }
            } else {
                print line
            }
        }
        close(target_file)

        # Collect blockers (non-terminal deps)
        deps = all_deps[target]
        if (deps != "") {
            n = split(deps, arr, ",")
            blocker_count = 0
            for (i = 1; i <= n; i++) {
                d = arr[i]
                if (d != "" && !is_terminal(statuses[d])) {
                    blocker_count++
                    blockers[blocker_count] = d
                }
            }
            if (blocker_count > 0) {
                print ""
                print "## Blockers"
                print ""
                for (i = 1; i <= blocker_count; i++) {
                    d = blockers[i]
                    printf "- %s [%s] %s\\n", d, statuses[d], titles[d]
                }
            }
        }

        # Show tickets this is blocking
        if (blocking_count > 0) {
            print ""
            print "## Blocking"
            print ""
            for (i = 1; i <= blocking_count; i++) {
                b = blocking[i]
                printf "- %s [%s] %s\\n", b, statuses[b], titles[b]
            }
        }

        # Show children
        if (children_count > 0) {
            print ""
            print "## Children"
            print ""
            for (i = 1; i <= children_count; i++) {
                c = children[i]
                printf "- %s [%s] %s\\n", c, statuses[c], titles[c]
            }
        }

        # Collect linked tickets
        links = all_links[target]
        if (links != "") {
            n = split(links, arr, ",")
            print ""
            print "## Linked"
            print ""
            for (i = 1; i <= n; i++) {
                l = arr[i]
                if (l != "") {
                    printf "- %s [%s] %s\\n", l, statuses[l], titles[l]
                }
            }
        }
    }
    ' "${ticket_files[@]}" 2>/dev/null
    
    # Display AC completion if checkboxes exist
    local total_ac checked_ac pct
    total_ac=$(grep -c '^- \\[[\ x]\\]' "$file" 2>/dev/null || true)
    checked_ac=$(grep -c '^- \\[x\\]' "$file" 2>/dev/null || true)
    
    # Strip any whitespace
    total_ac=$(echo "$total_ac" | tr -d ' \\n')
    checked_ac=$(echo "$checked_ac" | tr -d ' \\n')
    
    if [[ "$total_ac" -gt 0 ]] 2>/dev/null; then
        pct=$((checked_ac * 100 / total_ac))
        echo "**Acceptance Criteria:** $checked_ac/$total_ac complete ($pct%)"
    fi
}

cmd_add_note() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: tix add-note <id> [note text]" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    shift

    local note
    if [[ $# -gt 0 ]]; then
        note="$*"
    elif [[ ! -t 0 ]]; then
        # Read from stdin
        note=$(cat)
        # Check if the piped input is likely the 'tix help' output
        local cmd_name
        cmd_name=$(basename "$0") # Get the script name (e.g., tix)
        if echo "$note" | head -n 1 | grep -q "^$cmd_name - minimal ticket system with dependency tracking"; then
            echo "Error: Refusing to add CLI help text as a note. Did you pipe 'tix help' by mistake?" >&2
            return 1
        fi
    else
        echo "Error: no note provided" >&2
        return 1
    fi

    local timestamp
    timestamp=$(_iso_date)

    # Add Notes section if missing
    if ! grep -q '^## Notes' "$file"; then
        printf '\\n## Notes\\n' >> "$file"
    fi
    
    # Append timestamped note, ensuring markdown and special characters are preserved
    printf '\\n**%s**\\n\\n' "$timestamp" >> "$file"
    printf '%s\\n' "$note" >> "$file"

    echo "Note added to $(basename "$file" .md)"
}

cmd_check() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: tix check <id> <ac-number>" >&2
        echo "       Toggle acceptance criterion checkbox (1-indexed)" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    local ac_num="$2"

    # Find the Acceptance Criteria section and toggle the Nth checkbox
    local temp_file
    temp_file=$(mktemp) || { echo "Error: Failed to create temporary file" >&2; return 1; }
    awk -v n="$ac_num" '
    BEGIN { in_ac=0; checkbox_count=0 }
    /^## Acceptance Criteria/ { in_ac=1; print; next }
    /^## / && in_ac { in_ac=0 }
    in_ac && /^- \\[[\ x]\\]/ {
        checkbox_count++
        if (checkbox_count == n) {
            if (/^- \\[ \\]/) {
                sub(/^- \\[ \\]/, "- [x]")
            } else {
                sub(/^- \\[x\\]/, "- [ ]")
            }
        }
    }
    { print }
    ' "$file" > "$temp_file" && mv "$temp_file" "$file" || { rm -f "$temp_file"; return 1; }

    echo "Toggled AC #$ac_num in $(basename "$file" .md)"
}

cmd_add_ac() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: tix add-ac <id> <criterion text>" >&2
        echo "       Add acceptance criterion checkbox to ticket" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    shift
    local new_ac="$*"

    # Sanitize new_ac for awk: remove newlines and escape single quotes
    local new_ac_safe
    new_ac_safe=$(echo "$new_ac" | tr -s '\\n' ' ' | sed "s/'/'\\\''/g" | sed 's/ *$//')

    # Find AC section and append, or create section if missing
    local temp_file
    temp_file=$(mktemp) || { echo "Error: Failed to create temporary file" >&2; return 1; }
    awk -v new_ac="$new_ac_safe" '
    BEGIN { in_ac=0; found_ac=0; added=0; last_was_blank=0 }
    
    /^## Acceptance Criteria/ {
        found_ac=1
        in_ac=1
        print
        next
    }
    
    /^## / && in_ac && !added {
        # End of AC section, insert before next heading
        print "- [ ] " new_ac
        added=1
        in_ac=0 # Stop processing ACs
        print # Print the current heading
        next
    }
    
    # If in AC section and not a blank line or a new heading, print
    in_ac && NF > 0 && !/^## / { print }
    # Handle blank lines after ACs to ensure proper formatting
    in_ac && NF == 0 { last_was_blank=1; print; next } # Preserve blank lines
    
    # If outside AC section, or after ACs were added, just print
    !in_ac { print }
    
    END {
        # If AC section not found at all, append it
        if (!found_ac) {
            print ""
            print "## Acceptance Criteria"
            print "- [ ] " new_ac
        }
    }' "$file" > "$temp_file" && mv "$temp_file" "$file" || { rm -f "$temp_file"; return 1; }

    echo "Added AC to $(basename "$file" .md): $new_ac"
}


cmd_remove_ac() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: tix remove-ac <id> <ac-number>" >&2
        echo "       Remove acceptance criterion from ticket (1-indexed)" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    local ac_num="$2"

    if ! [[ "$ac_num" =~ ^[1-9][0-9]*$ ]]; then
        echo "Error: AC number must be a positive integer." >&2
        return 1
    fi

    local removed_ac_text=""

    # Use awk to remove the Nth AC and capture its text
    local awk_script='BEGIN { in_ac=0; checkbox_count=0; print_line=1; removed_text="" }
/^## Acceptance Criteria/ { in_ac=1; print; next }
/^## / && in_ac { in_ac=0; print; next }
in_ac && /^- \[ \]/ {
    checkbox_count++;
    if (checkbox_count == n) {
        print_line=0; # Skip printing this line
        removed_text = substr($0, index($0, "] ") + 2); # Capture AC text after ]
    }
}
print_line { print }
END { print removed_text > "/dev/stderr" }'

    local temp_file
    temp_file=$(mktemp) || { echo "Error: Failed to create temporary file" >&2; return 1; }
    removed_ac_text=$(awk -v n="$ac_num" "$awk_script" "$file" 2>&1 >"$temp_file") || { rm -f "$temp_file"; return 1; }
    
    # Check if a line was actually removed
    if [[ -z "$removed_ac_text" ]]; then
        echo "Error: AC #$ac_num not found in $(basename "$file" .md)" >&2
        rm -f "$temp_file" # Clean up temp file
        return 1
    fi

    mv "$temp_file" "$file" || { rm -f "$temp_file"; return 1; }

    echo "Removed AC #$ac_num from $(basename "$file" .md): $removed_ac_text"
}


main_help() {
    cat <<EOF
tix - minimal ticket system with dependency tracking

Usage: tix <command> [arguments]

Commands:
  create <title> [--description <desc>] [--design <design>] [--acceptance <ac>]
                 [--priority <p>] [--type <type>] [--assignee <assignee>]
                 [--external-ref <ref>] [--parent <id>] [--tags <tag1,tag2>]
                 [-f|--folder <folder>]
    Create a new ticket. Title is required. Description, design, and acceptance
    criteria can be provided. Acceptance criteria can be separated by ';'.
    Use --folder to place in a subfolder (e.g., backlog, inbox). Auto-creates folder.
    Example: tix create "Implement user login" -d "User can log in" --acceptance "Show form; Validate input"
    Example: tix create "Maybe later" --folder backlog

    ls [--status=<status>] [--all] [--deep] [-a <assignee>] [-T <tag>]
        List active tickets (open, in-progress, on-hold) by default. Use --all to include done/closed.
        Use --deep to include tickets from subfolders and prefix nested results with [folder/path].
        Filters by status, assignee, or tag. Shows assignees in output.
        Examples: tix ls --status=in-progress -a "Winston", tix ls --deep --all

  show <id>
    Display a ticket's full details, including relationships.
    Example: tix show w-abcd

  status <id> <status>
    Update a ticket's status. Valid: open, in-progress, on-hold, done, closed.
    Auto-archives if status is terminal (done/closed).
    Example: tix status w-abcd in-progress

  start <id>
    Set ticket status to 'in-progress'.

  hold <id>  (alias: pause)
    Set ticket status to 'on-hold'. ⏸

  done <id>
    Set ticket status to 'done' (completed) and move to archive.

  close <id>
    Set ticket status to 'closed' (cancelled/won't-do) and move to archive.

  reopen <id>
    Set ticket status to 'open'.

    rename <id> <new-title>
        Rename a ticket by updating filename, YAML title, and markdown H1.
        Fails if the target filename already exists.
        Example: tix rename w-abcd "Improve login flow"

  dep <id> <dependency-id>
    Add a dependency from <id> to <dependency-id>.
    Example: tix dep w-abcd w-efgh (w-abcd depends on w-efgh)

  undep <id> <dependency-id>
    Remove a dependency.

  dep tree [id] [--full]
    Show dependency tree for a ticket or all tickets.
    --full: show all dependencies, not just active ones.

  dep cycle
    Find and display any dependency cycles.

  add-note <id> [note text]
    Add a timestamped note to a ticket. If note text is not provided,
    reads from stdin.
    Example: tix add-note w-abcd "Fixed a bug related to X."
    Example: echo "Detailed note." | tix add-note w-abcd

  check <id> <ac-number>
    Toggle an acceptance criterion (AC) checkbox for a ticket. AC numbers are 1-indexed.
    Example: tix check w-abcd 1 (toggles the first AC)

  add-ac <id> <criterion text>
    Add a new acceptance criterion to a ticket.
    Example: tix add-ac w-abcd "Ensure data is saved to DB."

  remove-ac <id> <ac-number>
    Remove an acceptance criterion from a ticket. AC numbers are 1-indexed.
    Example: tix remove-ac w-abcd 2 (removes the second AC)

  link <id1> <id2> [id3...]
    Create bidirectional links between tickets.
    Example: tix link w-abcd w-efgh w-ijkl

  unlink <id1> <id2>
    Remove a bidirectional link between two tickets.

  file <id>
    Print the full path to a ticket file.

    ready [--deep] [--assignee <assignee>] [--tag <tag>]
        List active tickets with all dependencies resolved (done/closed).
        Sorted by priority. Use --deep to include subfolders.

    blocked [--deep] [--assignee <assignee>] [--tag <tag>]
        List active tickets with unresolved dependencies.
        Use --deep to include subfolders. Shows which dependencies are blocking.

    closed [--limit=<num>] [--deep] [--archived] [-a <assignee>] [-T <tag>]
        List done/closed tickets. Defaults to 20.
        Use --archived to search the archive directory instead of tickets/.

  archive [--days=<num>] [--all]
    Move done/closed tickets to archive/YYYY-MM-DD/.
    --days: age in days (default 30). --all: archive all regardless of age.

  delete <id>
    Permanently delete a ticket file. Prompts for confirmation.
    Example: tix delete w-abcd

  vault <command>
    Obsidian vault integration. Use 'tix vault help' for subcommands.
    Examples: tix vault open, tix vault status, tix vault init

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        main_help
        return 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        help|-h|--help) main_help ;;
        create) cmd_create "$@" ;;
        ls) cmd_ls "$@" ;;
        show) cmd_show "$@" ;;
        status) cmd_status "$@" ;;
        start) cmd_start "$@" ;;
        hold|pause) cmd_hold "$@" ;;
        done) cmd_done "$@" ;;
        close) cmd_close "$@" ;;
        reopen) cmd_reopen "$@" ;;
        rename) cmd_rename "$@" ;;
        dep) cmd_dep "$@" ;;
        undep) cmd_undep "$@" ;;
        add-note) cmd_add_note "$@" ;;
        check) cmd_check "$@" ;;
        add-ac) cmd_add_ac "$@" ;;
        remove-ac) cmd_remove_ac "$@" ;;
        link) cmd_link "$@" ;;
        unlink) cmd_unlink "$@" ;;
        file) cmd_file "$@" ;;
        ready) cmd_ready "$@" ;;
        blocked) cmd_blocked "$@" ;;
        closed) cmd_closed "$@" ;;
        archive) cmd_archive "$@" ;;
        delete) cmd_delete "$@" ;;
        vault) cmd_vault "$@" ;;
        *)
            echo "Unknown command: $cmd" >&2
            main_help
            return 1
            ;;
    esac
}

main "$@"
