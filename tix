    current_deps=$(yaml_field "$file" "deps")

    if ! echo "$current_deps" | _grep -q "$dep_id"; then
        echo "Dependency not found"
        return 1
    fi

    # Remove dep from array
    local new_deps
    new_deps=$(echo "$current_deps" | sed "s/, *$dep_id//g; s/$dep_id, *//g; s/$dep_id//g")
