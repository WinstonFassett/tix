cmd_vault_open() {
    # Determine workspace root
    local workspace_root
    workspace_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "$SCRIPT_DIR/..")
    workspace_root=$(realpath "$workspace_root")

    # Ensure .obsidian directory exists
    local obsidian_dir="$workspace_root/.obsidian"
    if [[ ! -d "$obsidian_dir" ]]; then
        echo "Vault not initialized. Creating vault marker..."
        mkdir -p "$obsidian_dir"
        echo "Created Obsidian vault marker: $obsidian_dir"
    fi

    # Determine what to open
    local target_file=""
    if [[ $# -gt 0 && -n "$1" ]]; then
        # Try to resolve as a ticket ID
        local ticket_file
        ticket_file=$(ticket_path "$1" 2>/dev/null) || true
        if [[ -n "$ticket_file" && -f "$ticket_file" ]]; then
            target_file="$ticket_file"
        else
            echo "Ticket '$1' not found. Opening vault overview." >&2
        fi
    fi

    # If no specific file, try to open a dashboard or main view
    if [[ -z "$target_file" ]]; then
        # Look for common dashboard files in order of preference
        local dashboard_files=(
            "$workspace_root/views/Ticket Dashboard.md"
            "$workspace_root/views/Tickets Board.md"
            "$workspace_root/README.md"
        )
        
        for dashboard in "${dashboard_files[@]}"; do
            if [[ -f "$dashboard" ]]; then
                target_file="$dashboard"
                break
            fi
        done
    fi

    # Construct and execute Obsidian URI
    if [[ -n "$target_file" && -f "$target_file" ]]; then
        local encoded_path
        encoded_path=$(realpath "$target_file" | sed 's/ /%20/g')
        echo "Opening in Obsidian: $(basename "$target_file")"
        open "obsidian://open?path=$encoded_path"
    else
        # Fallback: open vault directory (Obsidian will show file browser)
        local encoded_root
        encoded_root=$(echo "$workspace_root" | sed 's/ /%20/g')
        echo "Opening Obsidian vault: $(basename "$workspace_root")"
        open "obsidian://open?path=$encoded_root"
    fi
}

add_link_to_file() {
    local file="$1"
    local target_id="$2"

    local current_links
    current_links=$(yaml_field "$file" "links" || true)
    [[ -z "$current_links" ]] && current_links="[]"

    # Skip if already present
    if echo "$current_links" | _grep -q "$target_id"; then
        return 0
    fi

    if [[ "$current_links" == "[]" ]]; then
        update_yaml_field "$file" "links" "[$target_id]"
