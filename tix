        if (show_paths != "1") return ""
        rel_path = file
        if (index(rel_path, tickets_dir "/") == 1) rel_path = substr(rel_path, length(tickets_dir) + 2)
        folder = rel_path
        sub("/[^/]+$", "", folder)
        if (folder != rel_path && folder != "") return "[" folder "] "
        return ""
    }
    function is_terminal(s) {
        return (s == "done" || s == "closed" || s == "completed" || s == "finished" || s == "resolved" || s == "cancelled" || s == "canceled" || s == "wontfix")
    }
    function emit() {
        if (title == "" && fm_title != "") title = fm_title
        if (id != "" && is_terminal(status) &&
            (assignee_filter == "" || assignee == assignee_filter) &&
            (tag_filter == "" || has_tag(tags, tag_filter))) {
            cmd = "stat -f %m \"" FILENAME "\" 2>/dev/null || stat -c %Y \"" FILENAME "\" 2>/dev/null"
            cmd | getline mtime
            close(cmd)
            actual_status[id] = status
            titles[id] = title " [" assignee "]"
            prefixes[id] = nested_prefix(prev_file)
            mtimes[id] = mtime
        }
    }
    END {
        if (prev_file) emit()

        count = 0
        for (id in mtimes) {
            output[++count] = sprintf("%s|%s|%s", mtimes[id], id, tickets[id])
        }

        for (i = 1; i <= count; i++) {
            for (j = i + 1; j <= count; j++) {
                split(output[i], a, "|")
                split(output[j], b, "|")
                if (a[1] < b[1] || (a[1] == b[1] && a[2] > b[2])) {
                    tmp = output[i]; output[i] = output[j]; output[j] = tmp
                }
            }
        }

        shown = 0
        for (i = 1; i <= count; i++) {
            if (shown >= limit) break
            split(output[i], f, "|")
            printf "%s%-8s [%s] %s\n", prefixes[f[2]], f[2], actual_status[f[2]], titles[f[2]]
            shown++
        }

        if (shown == 0) {
            print "No closed/done tickets found"
        } else if (count >= limit) {
            print "(" shown " of " count " total, showing recent " limit ")"
        }
    }
    ' "${ticket_files[@]}" 2>/dev/null
}

cmd_blocked() {
    [[ ! -d "$TICKETS_DIR" ]] && return 0

    local assignee_filter="" tag_filter="" deep_mode=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --deep) deep_mode=1; shift ;;
            -a) assignee_filter="$2"; shift 2 ;;
            --assignee=*) assignee_filter="${1#--assignee=}"; shift ;;
            -T) tag_filter="$2"; shift 2 ;;
            --tag=*) tag_filter="${1#--tag=}"; shift ;;
            *) shift ;;
        esac
    done

    local -a ticket_files=()
    while IFS= read -r -d '' file; do
        ticket_files+=("$file")
    done < <(collect_ticket_files "$deep_mode" 0)
    [[ ${#ticket_files[@]} -eq 0 ]] && return 0

    awk -v assignee_filter="$assignee_filter" -v tag_filter="$tag_filter" -v show_paths="$deep_mode" -v tickets_dir="$TICKETS_DIR" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; fm_title=""; deps=""; priority=""; assignee=""; tags=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^title:/ { fm_title = substr($0, 8); gsub(/^["'\'']+|["'\'']+$/, "", fm_title) }
    in_front && /^status:/ { status = $2 }
    in_front && /^priority:/ { priority = $2 }
    in_front && /^assignee:/ { assignee = $2 }
    in_front && /^tags:/ { tags = $2; gsub(/[\[\] ]/, "", tags) }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function has_tag(tags_str, tag,    i, n, arr) {
        n = split(tags_str, arr, ",")
        for (i = 1; i <= n; i++) if (arr[i] == tag) return 1
        return 0
    }
    function nested_prefix(file,    rel_path, folder) {
        if (show_paths != "1") return ""
        rel_path = file
        if (index(rel_path, tickets_dir "/") == 1) rel_path = substr(rel_path, length(tickets_dir) + 2)
        folder = rel_path
        sub("/[^/]+$", "", folder)
        if (folder != rel_path && folder != "") return "[" folder "] "
        return ""
    }
    function is_terminal(s) {
        return (s == "done" || s == "closed" || s == "completed" || s == "finished" || s == "resolved" || s == "cancelled" || s == "canceled" || s == "wontfix")
    }
    function store() {
        if (title == "" && fm_title != "") title = fm_title
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            deps_raw[id] = deps
            priorities[id] = (priority != "") ? priority : 2
            assignees[id] = assignee
            all_tags[id] = tags
            prefixes[id] = nested_prefix(prev_file)
        }
    }
    END {
        if (prev_file) store()
        # Find blocked tickets: active with at least one dep not terminal
        for (id in statuses) {
            status = statuses[id]
            if (is_terminal(status)) continue
            if (status != "open" && status != "in-progress") continue
            if (assignee_filter != "" && assignees[id] != assignee_filter) continue
            if (tag_filter != "" && !has_tag(all_tags[id], tag_filter)) continue

            deps = deps_raw[id]
            if (deps == "") continue

            blocked = 0
            n = split(deps, arr, ",")
            for (i = 1; i <= n; i++) {
                dep = arr[i]
                if (dep != "" && !is_terminal(statuses[dep])) {
                    blocked = 1
                    break
                }
            }
            if (blocked) {
                # Build list of only non-terminal blockers
                blockers = ""
                n = split(deps, arr, ",")
                for (i = 1; i <= n; i++) {
                    dep = arr[i]
                    if (dep != "" && !is_terminal(statuses[dep])) {
                        blockers = (blockers == "") ? dep : blockers ", " dep
                    }
                }
                output[++count] = sprintf("%s|%s|%s|%s|[%s]|%s", priorities[id], id, status, titles[id], blockers, prefixes[id])
            }
        }

        # Sort by priority, then by id
        for (i = 1; i <= count; i++) {
            for (j = i + 1; j <= count; j++) {
                split(output[i], a, "|")
                split(output[j], b, "|")
                if (a[1] > b[1] || (a[1] == b[1] && a[2] > b[2])) {
                    tmp = output[i]; output[i] = output[j]; output[j] = tmp
                }
            }
        }

        for (i = 1; i <= count; i++) {
            split(output[i], f, "|")
            printf "%s%-8s [P%s][%s] - %s <- %s\n", f[6], f[2], f[1], f[3], f[4], f[5]
        }
    }
    ' "${ticket_files[@]}" 2>/dev/null
}

cmd_undep() {
