#!/usr/bin/env bash

set -euo pipefail # Exit on error, unset variables, and pipeline failures

# tix - minimal ticket system with dependency tracking
# Stores markdown files with YAML frontmatter in tickets/

# Find the script's directory (follow symlinks, macOS compatible)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Import libraries
source "$SCRIPT_DIR/lib/yaml_ops.sh"
source "$SCRIPT_DIR/lib/display_ops.sh"

# Validate input to prevent path traversal and injection attacks
validate_input() {
    local input="$1"
    local type="$2"  # 'path', 'id', 'general'
    
    case "$type" in
        'path')
            # Check for path traversal attempts
            if [[ "$input" =~ \.\./ ]] || [[ "$input" =~ \.\.\\/ ]]; then
                echo "Error: Path traversal detected in: $input" >&2
                return 1
            fi
            # Check for null bytes
            if [[ "$input" =~ $'\0' ]]; then
                echo "Error: Invalid characters in input" >&2
                return 1
            fi
            ;;
        'id')
            # Allow only alphanumeric characters, hyphens, and underscores for IDs
            if [[ ! "$input" =~ ^[a-zA-Z0-9_-]+$ ]]; then
                echo "Error: Invalid ID format: $input" >&2
                return 1
            fi
            ;;
        'general')
            # Check for null bytes and dangerous control characters
            if [[ "$input" =~ $'\0' ]]; then
                echo "Error: Invalid characters in input" >&2
                return 1
            fi
            ;;
    esac
    return 0
}

# Auto-setup dependencies if needed
if [[ ! -f "$SCRIPT_DIR/lib/yq" ]] || [[ ! -f "$SCRIPT_DIR/lib/jq" ]]; then
    echo "Dependencies not found. Setting up automatically..."
    "$SCRIPT_DIR/setup-deps"
fi

# Set tickets directory - check environment variable first, then current directory, then script local directory
# TIX_WORKSPACE takes precedence over TICKET_WORKSPACE (legacy fallback)
_WORKSPACE="${TIX_WORKSPACE:-${TICKET_WORKSPACE:-}}"
if [[ -n "$_WORKSPACE" ]]; then
    # Validate workspace path to prevent path traversal
    validate_input "$_WORKSPACE" "path" || {
        echo "Error: Invalid workspace path" >&2
        exit 1
    }
    TICKETS_DIR="$_WORKSPACE/tickets"
elif [[ -n "${TICKETS_DIR:-}" ]]; then
    # Respect explicit TICKETS_DIR setting
    # Validate TICKETS_DIR to prevent path traversal
    validate_input "$TICKETS_DIR" "path" || {
        echo "Error: Invalid TICKETS_DIR path" >&2
        exit 1
    }
    TICKETS_DIR="$TICKETS_DIR"
else
    # Default to current working directory (like Git)
    TICKETS_DIR="$(pwd)/tickets"
fi

# Convert to absolute path for clean output
if [[ -d "$TICKETS_DIR" ]]; then
    TICKETS_DIR="$(realpath "$TICKETS_DIR")"
else
    # If directory doesn't exist, resolve parent and append basename
    parent_dir="$(dirname "$TICKETS_DIR")"
    if [[ -d "$parent_dir" ]]; then
        parent_dir="$(realpath "$parent_dir")"
        TICKETS_DIR="$parent_dir/$(basename "$TICKETS_DIR")"
    else
        # Last resort - use current directory
        TICKETS_DIR="$(pwd)/tickets"
    fi
fi

# Prefer ripgrep if available, fall back to grep
if command -v rg &>/dev/null; then
    _grep() { rg "$@" 2>/dev/null; }
else
    _grep() { grep "$@" 2>/dev/null; }
fi

# Portable sha256 (Linux: sha256sum, macOS: shasum -a 256)
if command -v sha256sum &>/dev/null; then
    _sha256() { sha256sum; }
else
    _sha256() { shasum -a 256; }
fi

# Portable ISO date (GNU date supports -Iseconds, BSD date does not)
_iso_date() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

# Portable sed -i (BSD requires -i '', GNU uses -i)
_sed_i() {
    local file="$1"
    shift
    local tmp
    tmp=$(mktemp) || { echo "Error: Failed to create temporary file" >&2; return 1; }
    sed "$@" "$file" > "$tmp" && mv "$tmp" "$file" || { rm -f "$tmp"; return 1; }
}

# Generate simple 4-char ticket ID
generate_id() {
    # Better entropy: timestamp, PID, and random data
    local hash
    hash=$(echo "$$$(date +%s)$(openssl rand -hex 8 2>/dev/null || echo 'random')" | _sha256 | head -c 4)

    echo "$hash"
}

# Ensure tickets directory exists (auto-create if needed)
ensure_dir() {
    if [[ ! -d "$TICKETS_DIR" ]]; then
        mkdir -p "$TICKETS_DIR"
        echo "Created tickets directory: $TICKETS_DIR"
    fi
}

# Get all ticket files (supports subdirectories, excludes archive)
all_tickets() {
    find_ticket_files 1 1 | tr '\0' '\n'
}

# Find ticket files with optional recursion and archive exclusion.
find_ticket_files() {
    local deep_mode="${1:-1}"
    local exclude_archive="${2:-1}"

    if [[ "$deep_mode" == "1" ]]; then
        if [[ "$exclude_archive" == "1" ]]; then
            find "$TICKETS_DIR" -type f -name "*.md" -not -path "*/archive/*" -print0 2>/dev/null
        else
            find "$TICKETS_DIR" -type f -name "*.md" -print0 2>/dev/null
        fi
        return 0
    fi

    if [[ "$exclude_archive" == "1" ]]; then
        find "$TICKETS_DIR" \
            \( -type d ! -path "$TICKETS_DIR" -prune \) -o \
            \( -type f -name "*.md" -not -path "*/archive/*" -print0 \) 2>/dev/null
    else
        find "$TICKETS_DIR" \
            \( -type d ! -path "$TICKETS_DIR" -prune \) -o \
            \( -type f -name "*.md" -print0 \) 2>/dev/null
    fi
}

collect_ticket_files() {
    local deep_mode="${1:-1}"
    local exclude_archive="${2:-1}"

    while IFS= read -r -d '' file; do
        [[ ! -f "$file" || ! -r "$file" ]] && continue

        if grep -q "^---$" "$file" 2>/dev/null; then
            printf '%s\0' "$file"
        else
            echo "Warning: Skipping malformed file (no YAML frontmatter): $(basename "$file")" >&2
        fi
    done < <(find_ticket_files "$deep_mode" "$exclude_archive")
}

# Run AWK on all tickets (handles spaces in filenames)
run_awk_on_tickets() {
    local -a ticket_files
    while IFS= read -r -d '' file; do
        ticket_files+=("$file")
    done < <(find_ticket_files 1 0)
    awk "$@" "${ticket_files[@]}"
}

# Get ticket file path (supports partial ID matching)
ticket_path() {
    local id="$1"
    
    # Validate input to prevent path traversal
    validate_input "$id" "id" || return 1
    
    # Try exact match with paren format: "Title (ID).md"
    local exact
    exact=$(find "$TICKETS_DIR" -type f -name "*(${id}).md" 2>/dev/null | head -1)
    
    if [[ -f "$exact" ]]; then
        echo "$exact"
        return 0
    fi

    # Try partial match (anywhere in filename, for backwards compat or partial IDs)
    local matches
    matches=$(find "$TICKETS_DIR" -type f -name "*${id}*.md" 2>/dev/null | head -2)
    local count
    count=$(echo "$matches" | _grep -c . || true)

    if [[ "$count" -eq 1 ]]; then
        echo "$matches"
        return 0
    elif [[ "$count" -gt 1 ]]; then
        echo "Error: ambiguous ID '$id' matches multiple tickets" >&2
        return 1
    else
        echo "Error: ticket '$id' not found" >&2
        return 1
    fi
}

sanitize_title_for_filename() {
    local title="$1"

    # Keep spaces/capitalization intent while removing filename-unfriendly chars.
    local clean_title
    clean_title=$(echo "$title" | sed 's/[^a-zA-Z0-9 -]//g' | sed 's/  */ /g' | sed 's/^ //; s/ $//')

    # Ensure Title Case (capitalize first letter of each word)
    clean_title=$(echo "$clean_title" | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1)) tolower(substr($i,2))}} 1')

    if [[ -z "$clean_title" ]]; then
        clean_title="Untitled-Ticket"
    fi

    # Keep title readable, just truncate to 50 chars
    clean_title=$(echo "$clean_title" | cut -c 1-50 | sed 's/ *$//')

    # Fix common acronyms (with space boundaries)
    clean_title=$(echo "$clean_title" | sed -e 's/ Api / API /g' -e 's/ Api$/ API/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Ui / UI /g' -e 's/ Ui$/ UI/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Crud / CRUD /g' -e 's/ Crud$/ CRUD/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Sql / SQL /g' -e 's/ Sql$/ SQL/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Http / HTTP /g' -e 's/ Http$/ HTTP/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Rest / REST /g' -e 's/ Rest$/ REST/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Json / JSON /g' -e 's/ Json$/ JSON/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Xml / XML /g' -e 's/ Xml$/ XML/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Css / CSS /g' -e 's/ Css$/ CSS/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Html / HTML /g' -e 's/ Html$/ HTML/')
    clean_title=$(echo "$clean_title" | sed -e 's/ Url / URL /g' -e 's/ Url$/ URL/')

    echo "$clean_title"
}

update_ticket_h1() {
    local file="$1"
    local new_h1="$2"

    local temp_file
    temp_file=$(mktemp) || { echo "Error: Failed to create temporary file" >&2; return 1; }

    awk -v new_h1="$new_h1" '
    BEGIN { in_front=0; updated=0 }
    /^---$/ { in_front = !in_front; print; next }
    !in_front && updated == 0 && /^# / {
        print "# " new_h1
        updated = 1
        next
    }
    { print }
    ' "$file" > "$temp_file" && mv "$temp_file" "$file" || { rm -f "$temp_file"; return 1; }
}

cmd_create() {
    ensure_dir

    local title="" description="" design="" acceptance="" folder=""
    local priority=2 issue_type="task" assignee="" external_ref="" parent="" tags=""

    # Default assignee to git user.name if available
    assignee=$(git config user.name 2>/dev/null || true)

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--description) 
                description="$2"
                validate_input "$description" "general" || return 1
                shift 2 ;;
            --design) 
                design="$2"
                validate_input "$design" "general" || return 1
                shift 2 ;;
            --acceptance) 
                acceptance="$2"
                validate_input "$acceptance" "general" || return 1
                shift 2 ;;
            -p|--priority) 
                priority="$2"
                # Validate priority is numeric and within range
                if [[ ! "$priority" =~ ^[0-4]$ ]]; then
                    echo "Error: Priority must be 0-4" >&2
                    return 1
                fi
                shift 2 ;;
            -t|--type) 
                issue_type="$2"
                validate_input "$issue_type" "general" || return 1
                shift 2 ;;
            -a|--assignee) 
                assignee="$2"
                validate_input "$assignee" "general" || return 1
                shift 2 ;;
            --external-ref) 
                external_ref="$2"
                validate_input "$external_ref" "general" || return 1
                shift 2 ;;
            --parent) 
                parent="$2"
                validate_input "$parent" "id" || return 1
                shift 2 ;;
            --tags)
                tags="$2"
                validate_input "$tags" "general" || return 1
                shift 2 ;;
            -f|--folder)
                folder="$2"
                validate_input "$folder" "path" || return 1
                shift 2 ;;
            *)
                title="$1"
                validate_input "$title" "general" || return 1
                shift ;;
        esac
    done

    title="${title:-Untitled}"
    local id
    id=$(generate_id)
    
    local clean_title
    clean_title=$(sanitize_title_for_filename "$title")
    
    # Title-first format: "Title (ID).md"
    local target_dir="$TICKETS_DIR"
    if [[ -n "$folder" ]]; then
        target_dir="$TICKETS_DIR/$folder"
        mkdir -p "$target_dir"
    fi
    local file="$target_dir/${clean_title} (${id}).md"
    local now
    now=$(_iso_date)

    {
        echo "---"
        echo "id: $id"
        printf "title: \"%s\"\n" "$title"
        echo "status: open"
        echo "deps: []"
        echo "links: []"
        echo "created: $now"
        echo "type: $issue_type"
        echo "priority: $priority"
        [[ -n "$assignee" ]] && echo "assignee: $assignee"
        [[ -n "$external_ref" ]] && echo "external-ref: $external_ref"
        [[ -n "$parent" ]] && echo "parent: $parent"
        if [[ -n "$tags" ]]; then
            echo "tags: [task, ${tags//,/, }]"
        else
            echo "tags: [task]"
        fi
        echo "---"
        echo "# $clean_title"
        if [[ -n "$description" ]]; then
            echo "$description"
        fi
        if [[ -n "$design" ]]; then
            echo "## Design"
            echo "$design"
        fi
        if [[ -n "$acceptance" ]]; then
            echo "## Acceptance Criteria"
            # Convert semicolon-separated or newline-separated into checkboxes
            echo "$acceptance" | tr ';' '\n' | while IFS= read -r line; do
                [[ -n "$line" ]] && echo "- [ ] $line"
            done
        fi
    } > "$file"

    echo "Created ticket $id at:"
    echo "$file"
}

# Valid statuses
VALID_STATUSES="open in-progress on-hold done closed"
TERMINAL_STATUSES="done closed"
ACTIVE_STATUSES="open in-progress on-hold"

# Normalize status aliases to canonical values
# Returns canonical status on stdout, returns 1 if unrecognized
normalize_status() {
    local s="$1"
    case "$s" in
        open) echo "open" ;;
        in-progress|in_progress) echo "in-progress" ;;
        on-hold|on_hold|paused|hold) echo "on-hold" ;;
        done|completed|finished|resolved) echo "done" ;;
        closed|cancelled|canceled|wontfix) echo "closed" ;;
        *) return 1 ;;
    esac
}

# Check if a status (canonical or alias) is terminal
is_terminal_status() {
    local s="$1"
    local canonical
    canonical=$(normalize_status "$s") || return 1
    case "$canonical" in
        done|closed) return 0 ;;
        *) return 1 ;;
    esac
}

validate_status() {
    local status="$1"
    # Accept aliases — normalize will succeed if recognized
    if normalize_status "$status" >/dev/null; then
        return 0
    fi
    echo "Error: invalid status '$status'. Must be one of: $VALID_STATUSES" >&2
    return 1
}

cmd_status() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") status <id> <status>" >&2
        echo "Valid statuses: $VALID_STATUSES" >&2
        return 1
    fi

    local id="$1"
    local raw_status="$2"

    validate_status "$raw_status" || return 1
    local status
    status=$(normalize_status "$raw_status")

    local file
    file=$(ticket_path "$id") || return 1

    update_yaml_field "$file" "status" "$status"
    echo "Updated $(basename "$file" .md) -> $status"

    # Auto-archive if terminal
    if is_terminal_status "$status"; then
        _archive_ticket_by_id "$id"
    fi
}

cmd_start() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") start <id>" >&2
        return 1
    fi
    local id="$1"
    local file
    file=$(ticket_path "$id") || return 1
    update_yaml_field "$file" "status" "in-progress"
    echo "Ticket $id set to in-progress."
}

cmd_hold() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") hold <id>" >&2
        return 1
    fi
    local id="$1"
    local file
    file=$(ticket_path "$id") || return 1
    update_yaml_field "$file" "status" "on-hold"
    echo "Ticket $id set to on-hold. ⏸"
}

cmd_done() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") done <id>" >&2
        return 1
    fi
    local id="$1"
    local file
    file=$(ticket_path "$id") || return 1
    update_yaml_field "$file" "status" "done"
    echo "Ticket $id done."
    _archive_ticket_by_id "$id"
}

cmd_close() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") close <id>" >&2
        return 1
    fi
    local id="$1"
    local file
    file=$(ticket_path "$id") || return 1
    update_yaml_field "$file" "status" "closed"
    echo "Ticket $id closed."
    _archive_ticket_by_id "$id"
}

cmd_reopen() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") reopen <id>" >&2
        return 1
    fi
    local id="$1"
    local file
    file=$(ticket_path "$id") || return 1
    update_yaml_field "$file" "status" "open"
    echo "Ticket $id reopened successfully."
}

cmd_rename() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") rename <id> <new-title>" >&2
        return 1
    fi

    local id="$1"
    shift
    local new_title="$*"

    validate_input "$new_title" "general" || return 1

    local file
    file=$(ticket_path "$id") || return 1

    local ticket_id
    ticket_id=$(yaml_field "$file" "id" | tr -d '"')
    if [[ -z "$ticket_id" || "$ticket_id" == "null" ]]; then
        ticket_id=$(basename "$file" | sed -E 's/^.*\(([^()]*)\)\.md$/\1/')
    fi
    [[ -z "$ticket_id" || "$ticket_id" == "$(basename "$file")" ]] && ticket_id="$id"

    local clean_title
    clean_title=$(sanitize_title_for_filename "$new_title")

    local target_file
    target_file="$(dirname "$file")/${clean_title} (${ticket_id}).md"

    if [[ "$target_file" != "$file" && -e "$target_file" ]]; then
        echo "Error: target file already exists: $(basename "$target_file")" >&2
        return 1
    fi

    if [[ "$target_file" != "$file" ]]; then
        mv "$file" "$target_file"
        file="$target_file"
    fi

    update_yaml_field "$file" "title" "$new_title"
    update_ticket_h1 "$file" "$clean_title"

    echo "Renamed $(basename "$file" .md)"
}

_archive_ticket_by_id() {
    local id="$1"
    local file
    file=$(ticket_path "$id") || return 1 # Ensure file exists

    local today archive_dir
    today=$(_iso_date | cut -d'T' -f1) # Get YYYY-MM-DD
    archive_dir="$(dirname "$TICKETS_DIR")/archive/$today"

    mkdir -p "$archive_dir" # Ensure archive directory exists
    mv "$file" "$archive_dir/"
    echo "Archived: $(basename "$file" .md)"
}

cmd_dep_tree() {
    local full_mode=0
    local root_id=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full) full_mode=1; shift ;;
            *) root_id="$1"; shift ;;
        esac
    done

    if [[ -z "$root_id" ]]; then
        # No ID given - show all dependency trees
        echo "=== Dependency Trees ==="
        echo

        # Build file list properly handling spaces
        local -a ticket_files
        while IFS= read -r -d '' file; do
            ticket_files+=("$file")
        done < <(find "$TICKETS_DIR" -type f -name "*.md" -print0 2>/dev/null)

        [[ ${#ticket_files[@]} -eq 0 ]] && { echo "No tickets found."; return 0; }

        # Find root tickets (have dependents but nothing depends on them) and isolated count
        local roots_output
        roots_output=$(awk '
        BEGIN { FS=": "; in_front=0 }
        FNR==1 {
            if (prev_file) store()
            id=""; status=""; deps=""; in_front=0
            prev_file=FILENAME
        }
        /^---$/ { in_front = !in_front; next }
        in_front && /^id:/ { id = $2 }
        in_front && /^status:/ { status = $2 }
        in_front && /^deps:/ {
            deps = $2
            gsub(/[\[\] ]/, "", deps)
        }
        function is_terminal(s) {
            return (s == "done" || s == "closed" || s == "completed" || s == "finished" || s == "resolved" || s == "cancelled" || s == "canceled" || s == "wontfix")
        }
        function store() {
            if (id != "" && !is_terminal(status)) {
                all_ids[id] = 1
                has_outgoing_deps[id] = (deps != "") ? 1 : 0
                n = split(deps, arr, ",")
                for (i = 1; i <= n; i++) if (arr[i] != "") {
                    is_dependency[arr[i]] = 1
                }
            }
        }
        END {
            if (prev_file) store()

            # Find roots: tickets that are depended upon AND dont depend on anything
            # These are the base of dependency trees (leaf nodes that others build on)
            for (id in all_ids) {
                if ((id in is_dependency) && !has_outgoing_deps[id]) {
                    print "ROOT:" id
                }
            }

            # Count isolated tickets (no incoming or outgoing dependencies)
            isolated_count = 0
            for (id in all_ids) {
                if (!(id in is_dependency) && !has_outgoing_deps[id]) {
                    isolated_count++
                }
            }
            print "ISOLATED:" isolated_count
        }
        ' "${ticket_files[@]}" 2>/dev/null)

        local roots
        roots=$(echo "$roots_output" | grep '^ROOT:' | cut -d: -f2)
        local isolated_count
        isolated_count=$(echo "$roots_output" | grep '^ISOLATED:' | cut -d: -f2)

        if [[ -z "$roots" ]]; then
        echo "No dependency trees found."
        else
            # Show tree for each root
            local shown_any=0
            while IFS= read -r root; do
                if [[ -n "$root" ]]; then
                    if [[ $shown_any -eq 1 ]]; then
                        echo
                    fi
                    cmd_dep_tree_single "$root" "$full_mode"
                    shown_any=1
                fi
            done <<< "$roots"
        fi

        # Show isolated count
        if [[ -n "$isolated_count" && "$isolated_count" -gt 0 ]]; then
            echo
            echo "($isolated_count isolated tickets with no dependencies)"
        fi

        return 0
    fi

    cmd_dep_tree_single "$root_id" "$full_mode"
}

cmd_dep_tree_single() {
    local root_pattern="$1"
    local full_mode="$2"
    
    # Build file list properly handling spaces
    local -a ticket_files
    while IFS= read -r -d '' file; do
        ticket_files+=("$file")
    done < <(find "$TICKETS_DIR" -type f -name "*.md" -print0 2>/dev/null)

    awk -v root_pattern="$root_pattern" -v full_mode="$full_mode" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; fm_title=""; deps=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^title:/ { fm_title = substr($0, 8); gsub(/^["'\'']+|["'\'']+$/, "", fm_title) }
    in_front && /^status:/ { status = $2 }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function store() {
        if (title == "" && fm_title != "") title = fm_title
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            deps_str[id] = deps
            n = split(deps, arr, ",")
            for (i = 1; i <= n; i++) if (arr[i] != "") {
                dep_count[id]++
                dep_list[id, dep_count[id]] = arr[i]
            }
        }
    }

    END {
        if (prev_file) store()
        # Resolve partial ID
        root = ""
        for (id in statuses) {
            if (index(id, root_pattern) > 0) {
                if (root != "") {
                    print "Error: ambiguous ID " root_pattern > "/dev/stderr"
                    exit 1
                }
                root = id
            }
        }
        if (root == "") {
            print "Error: ticket " root_pattern " not found" > "/dev/stderr"
            exit 1
        }

        # Build inverse dependency map (who depends on whom)
        for (id in statuses) {
            n = split(deps_str[id], arr, ",")
            for (i = 1; i <= n; i++) {
                dep = arr[i]
                if (dep != "") {
                    inverse_dep_count[dep]++
                    inverse_dep_list[dep, inverse_dep_count[dep]] = id
                }
            }
        }

        # Find max depths using iterative approach with stack (now uses inverse_deps)
        stack[1] = root; stack_depth[1] = 0; stack_path[1] = ":"
        sp = 1
        while (sp > 0) {
            id = stack[sp]; depth = stack_depth[sp]; path = stack_path[sp]
            sp--

            if (!(id in statuses)) continue
            if (index(path, ":" id ":") > 0) continue

            if (!(id in max_depth) || depth > max_depth[id]) {
                max_depth[id] = depth
            }

            new_path = path id ":"
            for (i = 1; i <= inverse_dep_count[id]; i++) {
                child = inverse_dep_list[id, i]
                if (child != "") {
                    sp++
                    stack[sp] = child
                    stack_depth[sp] = depth + 1
                    stack_path[sp] = new_path
                }
            }
        }

        # Compute subtree depths (iterative post-order, now uses inverse_deps)
        delete stack; delete stack_depth; delete stack_path
        delete visited
        stack[1] = root; stack_path[1] = ":"; stack_phase[1] = 0
        sp = 1
        while (sp > 0) {
            id = stack[sp]; path = stack_path[sp]; phase = stack_phase[sp]

            if (!(id in statuses)) continue
            if (index(path, ":" id ":") > 0) { sp--; continue } # Protect against cycles

            if (phase == 0) {
                # First visit: push children
                stack_phase[sp] = 1
                new_path = path id ":"
                for (i = 1; i <= inverse_dep_count[id]; i++) {
                    child = inverse_dep_list[id, i]
                    if (child != "" && !(child in subtree_depth)) {
                        sp++
                        stack[sp] = child
                        stack_path[sp] = new_path
                        stack_phase[sp] = 0
                    }
                }
            } else {
                # Second visit: compute subtree depth
                max_sub = max_depth[id]
                for (i = 1; i <= inverse_dep_count[id]; i++) {
                    child = inverse_dep_list[id, i]
                    if (child in subtree_depth && subtree_depth[child] > max_sub) {
                        max_sub = subtree_depth[child]
                    }
                }
                subtree_depth[id] = max_sub
                sp--
            }
        }

        # Print tree (iterative with stack)
        print root " [" statuses[root] "] " titles[root]
        printed[root] = 1

        delete stack
        # Stack entries: id|depth|prefix|connector|path
        # Start with root children
        build_children(root, 0, "", "", ":" root ":")

        while (print_sp > 0) {
            id = print_stack_id[print_sp]
            depth = print_stack_depth[print_sp]
            prefix = print_stack_prefix[print_sp]
            connector = print_stack_conn[print_sp]
            path = print_stack_path[print_sp]
            print_sp--

            if (!(id in statuses)) continue
            if (!full_mode && (id in printed)) continue
            if (index(path, ":" id ":") > 0) continue
            if (!full_mode && depth != max_depth[id]) continue

            print prefix connector id " [" statuses[id] "] " titles[id]
            if (!full_mode) printed[id] = 1

            if (connector == "└── ") new_prefix = prefix "    "
            else new_prefix = prefix "│   "

            build_children(id, depth, new_prefix, connector, path id ":")
        }
    }

    function build_children(id, depth, prefix, connector, path,    i, child, n, arr, sorted, j, tmp, min_idx) {
        # Collect printable children (now using inverse_dep_list)
        n = 0
        for (i = 1; i <= inverse_dep_count[id]; i++) {
            child = inverse_dep_list[id, i]
            if (child == "") continue
            if (!full_mode && (child in printed)) continue
            if (!(child in max_depth)) continue
            if (!full_mode && depth + 1 != max_depth[child]) continue
            if (index(path, ":" child ":") > 0) continue
            n++
            arr[n] = child
        }
        if (n == 0) return

        # Sort by subtree_depth, then by ticket ID (insertion sort)
        for (i = 2; i <= n; i++) {
            tmp = arr[i]
            j = i - 1
            while (j >= 1 && (subtree_depth[arr[j]] > subtree_depth[tmp] || \\
                   (subtree_depth[arr[j]] == subtree_depth[tmp] && arr[j] > tmp))) {
                arr[j + 1] = arr[j]
                j--
            }
            arr[j + 1] = tmp
        }

        # Push to stack in reverse order (so first prints first)
        for (i = n; i >= 1; i--) {
            child = arr[i]
            print_sp++
            print_stack_id[print_sp] = child
            print_stack_depth[print_sp] = depth + 1
            print_stack_prefix[print_sp] = prefix
            if (i == n) print_stack_conn[print_sp] = "└── "
            else print_stack_conn[print_sp] = "├── "
            print_stack_path[print_sp] = path
        }
    }
    ' "${ticket_files[@]}" 2>/dev/null
}

cmd_dep_cycle() {
    [[ ! -d "$TICKETS_DIR" ]] && return 0
    
    # Build file list properly handling spaces
    local -a ticket_files
    while IFS= read -r -d '' file; do
        ticket_files+=("$file")
    done < <(find "$TICKETS_DIR" -type f -name "*.md" -print0 2>/dev/null)

    awk '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; fm_title=""; deps=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^title:/ { fm_title = substr($0, 8); gsub(/^["'\'']+|["'\'']+$/, "", fm_title) }
    in_front && /^status:/ { status = $2 }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function is_terminal(s) {
        return (s == "done" || s == "closed" || s == "completed" || s == "finished" || s == "resolved" || s == "cancelled" || s == "canceled" || s == "wontfix")
    }
    function store() {
        if (title == "" && fm_title != "") title = fm_title
        if (id != "" && !is_terminal(status)) {
            statuses[id] = status
            titles[id] = title
            deps_str[id] = deps
            n = split(deps, arr, ",")
            for (i = 1; i <= n; i++) if (arr[i] != "") {
                dep_count[id]++
                dep_list[id, dep_count[id]] = arr[i]
            }
        }
    }

    # DFS cycle detection
    function dfs(node, path, path_len,    i, child, result) {
        if (!(node in statuses)) return ""
        if (state[node] == 2) return ""  # black - fully visited
        if (state[node] == 1) {
            # gray - found cycle, extract it
            cycle = node
            for (i = path_len; i >= 1; i--) {
                cycle = path[i] " -> " cycle
                if (path[i] == node) break
            }
            return cycle
        }

        state[node] = 1  # gray - visiting
        path[path_len + 1] = node

        for (i = 1; i <= dep_count[node]; i++) {
            child = dep_list[node, i]
            result = dfs(child, path, path_len + 1)
            if (result != "") return result
        }

        state[node] = 2  # black - done
        return ""
    }

    END {
        if (prev_file) store()

        cycle_count = 0
        for (id in statuses) {
            if (state[id] == 0) {
                delete path
                result = dfs(id, path, 0)
                if (result != "") {
                    # Check if this cycle is already found (normalized)
                    # Extract cycle members
                    n = split(result, parts, " -> ")
                    # Normalize: find smallest ID as starting point
                    min_id = parts[1]
                    min_idx = 1
                    for (i = 2; i < n; i++) {  # skip last (duplicate of first)
                        if (parts[i] < min_id) {
                            min_id = parts[i]
                            min_idx = i
                        }
                    }
                    # Build normalized cycle string
                    norm = ""
                    for (i = 0; i < n - 1; i++) {
                        idx = ((min_idx - 1 + i) % (n - 1)) + 1
                        norm = (norm == "") ? parts[idx] : norm "," parts[idx]
                    }
                    # Check if already seen
                    if (!(norm in seen_cycles)) {
                        seen_cycles[norm] = 1
                        cycle_count++
                        cycles[cycle_count] = result
                        cycle_members[cycle_count] = norm
                    }
                }
            }
        }

        if (cycle_count == 0) {
            print "No dependency cycles found"
        } else {
            for (c = 1; c <= cycle_count; c++) {
                if (c > 1) print ""
                print "Cycle " c ": " cycles[c]
                n = split(cycle_members[c], members, ",")
                for (i = 1; i <= n; i++) {
                    id = members[i]
                    printf "  %-8s [%s] %s\\n", id, statuses[id], titles[id]
                }
            }
        }
    }
    ' "${ticket_files[@]}" 2>/dev/null
}

cmd_dep() {
    # Handle subcommands
    if [[ "${1:-}" == "tree" ]]; then
        shift
        cmd_dep_tree "$@"
        return
    fi
    if [[ "${1:-}" == "cycle" ]]; then
        shift
        cmd_dep_cycle "$@"
        return
    fi

    if [[ $# -lt 2 ]]; then
        echo "Usage: tix dep <id> <dependency-id>" >&2
        echo "       tix dep tree <id>  - show dependency tree" >&2
        echo "       tix dep cycle      - find dependency cycles" >&2
        return 1
    fi

    local id="$1"
    local dep_id="$2"
    local file
    file=$(ticket_path "$id") || return 1

    # Verify dependency exists
    ticket_path "$dep_id" >/dev/null || return 1

    # Get current deps
    local current_deps
    current_deps=$(yaml_field "$file" "deps")

    # Add dep if not already present
    if echo "$current_deps" | _grep -q "$dep_id"; then
        echo "Dependency already exists"
        return 0
    fi

    # Update deps array
    if [[ "$current_deps" == "[]" ]]; then
        update_yaml_field "$file" "deps" "[$dep_id]"
    else
        local new_deps
        new_deps=$(echo "$current_deps" | sed "s/\\]/, $dep_id]/")
        update_yaml_field "$file" "deps" "$new_deps"
    fi

    echo "Added dependency: $(basename "$file" .md) -> $dep_id"
}

