            printf "%s%-8s [P%s][%s] - %s\n", f[5], f[2], f[1], f[3], f[4]
        }
    }
    ' "${ticket_files[@]}" 2>/dev/null
}

cmd_archive() {
    [[ ! -d "$TICKETS_DIR" ]] && return 0

    local days=30 all_closed=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --days=*) days="${1#--days=}"; shift ;;
            --days) days="$2"; shift 2 ;;
            --all) all_closed=1; shift ;;
            *) shift ;;
        esac
    done

    local today archive_dir
    today=$(_iso_date | cut -d'T' -f1)
    archive_dir="$(dirname "$TICKETS_DIR")/archive/$today"

    local cutoff_ts=0
    if [[ $all_closed -eq 0 ]]; then
        # Calculate cutoff timestamp (now - days)
        if date --version &>/dev/null 2>&1; then
            # GNU date
            cutoff_ts=$(date -d "$days days ago" +%s)
        else
            # BSD date (macOS)
            cutoff_ts=$(date -v-${days}d +%s)
        fi
    fi

    # Build file list
    local tmp_file_list="/tmp/ticket_archive_files_$$"
    find "$TICKETS_DIR" -type f -name "*.md" -not -path "*/archive/*" -print0 2>/dev/null > "$tmp_file_list"

    local archived=0
    while IFS= read -r -d '' file; do
        # Skip files that don't exist or aren't readable
        [[ ! -f "$file" || ! -r "$file" ]] && continue
        
        # Check if file has valid YAML frontmatter
        if ! grep -q "^---$" "$file"; then
            echo "Warning: Skipping malformed file (no YAML frontmatter): $(basename "$file")" >&2
            continue
        fi
        
        # Check if terminal status
        local status
        status=$(sed -n '/^---$/,/^---$/p' "$file" 2>/dev/null | grep "^status:" | sed 's/^status: *//' | sed 's/"//g' || echo "")

        # Skip if status is empty or not terminal
        [[ -z "$status" ]] && continue
        is_terminal_status "$status" || continue

        # Check age if not --all
        if [[ $all_closed -eq 0 ]]; then
            local file_ts
            file_ts=$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null || echo "0")
            [[ $file_ts -gt $cutoff_ts ]] && continue
        fi

        # Archive it
        mkdir -p "$archive_dir"
        mv "$file" "$archive_dir/"
        echo "Archived: $(basename "$file" .md)"
        ((archived++))
    done < "$tmp_file_list"

    # Cleanup temp file
    rm -f "$tmp_file_list"

    if [[ $archived -eq 0 ]]; then
        echo "No tickets to archive"
    else
        echo "Archived $archived ticket(s) to archive/$today/"
    fi
}

