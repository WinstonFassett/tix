        for (i = 1; i <= n; i++) if (arr[i] == tag) return 1
        return 0
    }
    function nested_prefix(file,    rel_path, folder) {
        if (show_paths != "1") return ""
        rel_path = file
        if (index(rel_path, tickets_dir "/") == 1) rel_path = substr(rel_path, length(tickets_dir) + 2)
        folder = rel_path
        sub("/[^/]+$", "", folder)
        if (folder != rel_path && folder != "") return "[" folder "] "
