#!/usr/bin/env bash
set -euo pipefail
# Resolve symlinks to find the real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
UI_DIR="$(dirname "$SCRIPT_DIR")"
OUTPUT="$UI_DIR/.output/server/index.mjs"

# Default TIX_WORKSPACE to cwd if not set (dev server needs this too)
export TIX_WORKSPACE="${TIX_WORKSPACE:-$(pwd)}"

# Check for tickets dir
if [[ ! -d "$TIX_WORKSPACE/tickets" ]]; then
    echo "No tickets/ directory found at $TIX_WORKSPACE"
    echo "Run from a directory with tickets/ or set TIX_WORKSPACE"
    exit 1
fi

# Derive project-scoped name for portless (e.g. talky-tix, web-dev-mcp-tix).
# PORTLESS_NAME overrides the derived subdomain (useful for dated/verbose dir names).
PROJECT_NAME="$(basename "$TIX_WORKSPACE")"
APP_NAME="${PORTLESS_NAME:-${PROJECT_NAME}-tix}"

# Detect portless availability (respect PORTLESS=0 bypass)
if [[ "${PORTLESS:-1}" != "0" ]] && command -v portless >/dev/null 2>&1; then
    USE_PORTLESS=1
    URL="http://${APP_NAME}.localhost:${PORTLESS_PORT:-1355}"
else
    USE_PORTLESS=0
    # Find an available port starting from PORT or 3000
    PORT="${PORT:-3000}"
    while lsof -ti "tcp:$PORT" >/dev/null 2>&1; do
        PORT=$((PORT + 1))
    done
    export PORT
    URL="http://localhost:$PORT"
fi

# Wait for the server to actually respond, then open the browser.
# $1 = URL to open (and poll for readiness).
# With portless the proxy responds 404 before the backend registers,
# so we require a non-404 response to confirm the app is truly up.
wait_then_open() {
    local url="$1"
    local tries=0
    local code
    while true; do
        code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 1 "$url" 2>/dev/null)" || code=000
        # Wait for a 2xx/3xx — proxy returns 404 (not registered) or 502
        # (backend not listening yet) before the app is truly ready.
        [[ "$code" =~ ^[23] ]] && break
        tries=$((tries + 1))
        if [[ $tries -gt 600 ]]; then  # ~60s total
            echo "tix-ui: server did not start within 60s, skipping auto-open" >&2
            return 0
        fi
        sleep 0.1
    done
    if command -v open >/dev/null 2>&1; then
        open "$url"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
    fi
}

# Dev mode: run vite dev server from source dir for HMR
if [[ "${TIX_UI_DEV:-}" == "1" ]]; then
    echo "tix-ui (dev) → $URL  (workspace: $TIX_WORKSPACE)"
    wait_then_open "$URL" &
    cd "$UI_DIR"
    if [[ "$USE_PORTLESS" == "1" ]]; then
        exec portless "$APP_NAME" vite dev "$@"
    elif command -v bun >/dev/null 2>&1; then
        exec bun run dev --port "$PORT" "$@"
    elif command -v pnpm >/dev/null 2>&1; then
        exec pnpm dev --port "$PORT" "$@"
    else
        exec npm run dev -- --port "$PORT" "$@"
    fi
fi

if [[ ! -f "$OUTPUT" ]]; then
    echo "tix-ui not built. Run: cd $UI_DIR && npm run build"
    exit 1
fi

echo "tix-ui → $URL  (workspace: $TIX_WORKSPACE)"

wait_then_open "$URL" &

if [[ "$USE_PORTLESS" == "1" ]]; then
    exec portless "$APP_NAME" node "$OUTPUT" "$@"
else
    exec node "$OUTPUT" "$@"
fi
