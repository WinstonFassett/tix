#!/usr/bin/env bash
set -euo pipefail

# install-tix-ui - Install tix-ui dependencies and symlink the CLI

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADMIN_DIR="$SCRIPT_DIR/tix-ui"

if ! command -v node >/dev/null 2>&1; then
    echo "Skipping tix-ui: node not found"
    exit 0
fi

echo "Installing tix-ui dependencies..."
(cd "$ADMIN_DIR" && npm install --silent)

INSTALL_DIR="/usr/local/bin"
if [[ $EUID -ne 0 ]]; then
    INSTALL_DIR="$HOME/.local/bin"
    mkdir -p "$INSTALL_DIR"
fi

chmod +x "$ADMIN_DIR/bin/cli.js"
ln -sf "$ADMIN_DIR/bin/cli.js" "$INSTALL_DIR/tix-ui"
echo "tix-ui installed to $INSTALL_DIR/tix-ui"
