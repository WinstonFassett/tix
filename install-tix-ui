#!/usr/bin/env bash
set -euo pipefail

# install-tix-ui - Build tix-ui and symlink a launcher

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UI_DIR="$SCRIPT_DIR/tix-ui"

if ! command -v node >/dev/null 2>&1; then
    echo "Skipping tix-ui: node not found"
    exit 0
fi

# Install deps
echo "Installing tix-ui dependencies..."
if command -v bun >/dev/null 2>&1; then
    (cd "$UI_DIR" && bun install --silent)
else
    (cd "$UI_DIR" && npm install --silent)
fi

# Build
echo "Building tix-ui..."
(cd "$UI_DIR" && npm run build --silent)

mkdir -p "$UI_DIR/bin"

# Create launcher script
cat > "$UI_DIR/bin/tix-ui" << 'LAUNCHER'
#!/usr/bin/env bash
set -euo pipefail
# Resolve symlinks to find the real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
UI_DIR="$(dirname "$SCRIPT_DIR")"
OUTPUT="$UI_DIR/.output/server/index.mjs"

# Default TIX_WORKSPACE to cwd if not set (dev server needs this too)
export TIX_WORKSPACE="${TIX_WORKSPACE:-$(pwd)}"

# Check for tickets dir
if [[ ! -d "$TIX_WORKSPACE/tickets" ]]; then
    echo "No tickets/ directory found at $TIX_WORKSPACE"
    echo "Run from a directory with tickets/ or set TIX_WORKSPACE"
    exit 1
fi

# Find an available port starting from PORT or 3000
PORT="${PORT:-3000}"
while lsof -ti "tcp:$PORT" >/dev/null 2>&1; do
    PORT=$((PORT + 1))
done
export PORT

# Dev mode: run vite dev server from source dir for HMR
if [[ "${TIX_UI_DEV:-}" == "1" ]]; then
    echo "tix-ui (dev) → http://localhost:$PORT  (workspace: $TIX_WORKSPACE)"
    if command -v open >/dev/null 2>&1; then
        open "http://localhost:$PORT" &
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "http://localhost:$PORT" &
    fi
    cd "$UI_DIR"
    if command -v pnpm >/dev/null 2>&1; then
        exec pnpm dev --port "$PORT" "$@"
    elif command -v bun >/dev/null 2>&1; then
        exec bun run dev --port "$PORT" "$@"
    else
        exec npm run dev -- --port "$PORT" "$@"
    fi
fi

if [[ ! -f "$OUTPUT" ]]; then
    echo "tix-ui not built. Run: cd $UI_DIR && npm run build"
    exit 1
fi

echo "tix-ui → http://localhost:$PORT  (workspace: $TIX_WORKSPACE)"

# Auto-open browser
if command -v open >/dev/null 2>&1; then
    open "http://localhost:$PORT" &
elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "http://localhost:$PORT" &
fi

exec node "$OUTPUT" "$@"
LAUNCHER

chmod +x "$UI_DIR/bin/tix-ui"

# Symlink
INSTALL_DIR="/usr/local/bin"
if [[ $EUID -ne 0 ]]; then
    INSTALL_DIR="$HOME/.local/bin"
    mkdir -p "$INSTALL_DIR"
fi

ln -sf "$UI_DIR/bin/tix-ui" "$INSTALL_DIR/tix-ui"
echo "tix-ui installed to $INSTALL_DIR/tix-ui"
