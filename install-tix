#!/usr/bin/env bash
set -euo pipefail

# install-tix - Install tix globally like Git

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_DIR="/usr/local/bin"

echo "Installing tix globally..."

# Check if running with sudo for system install
if [[ $EUID -ne 0 ]]; then
    echo "Note: Installing for current user only"
    INSTALL_DIR="$HOME/.local/bin"
    mkdir -p "$INSTALL_DIR"

    # Add to PATH if not already there
    if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
        echo ""
        echo "Add $HOME/.local/bin to your PATH:"
        echo "   export PATH=\"\$HOME/.local/bin:\$PATH\""
        echo "   Add this to ~/.zshrc or ~/.bashrc"
    fi
fi

# Create symbolic link to the tix script
if ln -sf "$SCRIPT_DIR/tix" "$INSTALL_DIR/tix"; then
    echo "tix installed to $INSTALL_DIR/tix"
else
    echo "Installation failed"
    exit 1
fi

# Create backward-compat symlink for 'ticket' command
if ln -sf "$SCRIPT_DIR/ticket" "$INSTALL_DIR/ticket"; then
    echo "ticket compat wrapper installed to $INSTALL_DIR/ticket"
fi

# Verify installation
if "$INSTALL_DIR/tix" help >/dev/null 2>&1; then
    echo "Installation verified"
else
    echo "Installation verification failed"
    exit 1
fi

# Install tix-ui if node is available
if [[ -x "$SCRIPT_DIR/install-tix-ui" ]]; then
    "$SCRIPT_DIR/install-tix-ui"
fi

echo ""
echo "tix is now installed globally!"
echo ""
echo "Usage:"
echo "  tix create 'New task'      # Create ticket in current directory"
echo "  tix ls                     # List tickets"
echo "  tix help                   # Show all commands"
echo "  tix vault                  # Open workspace in Obsidian (also available as tix-vault)"
echo ""
echo "Works like Git - creates ./tickets/ in current directory by default"
